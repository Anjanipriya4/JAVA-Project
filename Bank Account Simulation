import java.util.*;
class BankAccount {
    int accNo;
    String name;
    double balance;
    ArrayList<String> history;
    BankAccount(int accNo, String name, double balance) {
        this.accNo = accNo;
        this.name = name;
        this.balance = balance;
        this.history = new ArrayList<>();
        history.add("Account created with balance: " + balance);
    }
    void deposit(double amount) {
        balance += amount;
        history.add("Deposited: " + amount);
        System.out.println("Deposit successful!");
    }
    void withdraw(double amount) {
        if (amount > balance) {
            System.out.println("Insufficient balance! ❌");
            return;
        }
        balance -= amount;
        history.add("Withdrawn: " + amount);
        System.out.println("Withdrawal successful!");
    }
    void showDetails() {
        System.out.println("Account No: " + accNo);
        System.out.println("Name: " + name);
        System.out.println("Balance: " + balance);
    }
    void showHistory() {
        System.out.println("Transaction History:");
        for (String h : history) {
            System.out.println(h);
        }
    }
}
public class Main {
    static Scanner sc = new Scanner(System.in);
    static ArrayList<BankAccount> accounts = new ArrayList<>();
    public static void main(String[] args) {
        while (true) {
            System.out.println("\n1.Create 2.Deposit 3.Withdraw 4.View 5.Transfer 6.History 7.Exit");
            if (!sc.hasNextInt()) break;
            int ch = sc.nextInt();
            switch (ch) {
                    System.out.print("Account No: ");
                    int accNo = sc.nextInt();
                    sc.nextLine();
                    System.out.print("Name: ");
                    String name = sc.nextLine();
                    System.out.print("Initial Balance: ");
                    double bal = sc.nextDouble();
                    accounts.add(new BankAccount(accNo, name, bal));
                    System.out.println("Account created!");
                    break;
                    BankAccount acc1 = findAccount();
                    if (acc1 != null) {
                        System.out.print("Amount: ");
                        acc1.deposit(sc.nextDouble());
                    }
                    break;
                    BankAccount acc2 = findAccount();
                    if (acc2 != null) {
                        System.out.print("Amount: ");
                        acc2.withdraw(sc.nextDouble());
                    }
                    break;
                    BankAccount acc3 = findAccount();
                    if (acc3 != null) acc3.showDetails();
                    break;
                    System.out.print("From Account: ");
                    int from = sc.nextInt();
                    System.out.print("To Account: ");
                    int to = sc.nextInt();

                    BankAccount sender = getAccount(from);
                    BankAccount receiver = getAccount(to);

                    if (sender != null && receiver != null) {
                        System.out.print("Amount: ");
                        double amt = sc.nextDouble();

                        if (amt > sender.balance) {
                            System.out.println("Insufficient balance! ❌");
                        } else {
                            sender.balance -= amt;
                            receiver.balance += amt;

                            sender.history.add("Transferred " + amt + " to " + to);
                            receiver.history.add("Received " + amt + " from " + from);

                            System.out.println("Transfer successful!");
                        }
                    } else {
                        System.out.println("Account not found!");
                    }
                    break;
                    BankAccount acc4 = findAccount();
                    if (acc4 != null) acc4.showHistory();
                    break;
                    return;
                default:
                    System.out.println("Invalid choice!");
            }
        }
    }
    static BankAccount findAccount() {
        System.out.print("Enter Account No: ");
        int id = sc.nextInt();
        BankAccount acc = getAccount(id);

        if (acc == null) {
            System.out.println("Account not found!");
        }
        return acc;
    }
    static BankAccount getAccount(int id) {
        for (BankAccount b : accounts) {
            if (b.accNo == id) return b;
        }
        return null;
    }
}
